///|
fn render_lepus_command_codegen(
  parsed : ParsedLepusModule,
  extension_id : String,
  js_namespace : String,
) -> LepusCommandCodegenOutput {
  let builder = StringBuilder::new()
  builder.write_string("///|\n")
  builder.write_string(
    "/// Generated by `lepus codegen`. Do not edit by hand.\n",
  )
  builder.write_string("\n")
  render_event_helpers(builder, parsed.events)
  render_payloads_and_wrappers(builder, parsed.commands)
  render_extension_spec(
    builder,
    parsed.commands,
    parsed.scripts,
    parsed.destroy,
    extension_id,
    js_namespace,
  )
  LepusCommandCodegenOutput::{
    source: builder.to_string(),
    warnings: codegen_warnings(parsed),
  }
}

///|
fn render_event_helpers(
  builder : StringBuilder,
  events : Array[ParsedLepusEvent],
) -> Unit {
  for event in events {
    builder.write_string("///|\n")
    builder.write_string("pub async fn ")
    builder.write_string(event.helper_name)
    builder.write_string("(\n")
    builder.write_string(
      "  context : @lepus_command.AppCommandExtensionContext,\n",
    )
    builder.write_string("  payload : ")
    builder.write_string(event.type_name)
    builder.write_string(",\n")
    builder.write_string(") -> Unit {\n")
    builder.write_string("  context.emit(")
    builder.write_string(mbt_string(event.js_name))
    builder.write_string(", payload)\n")
    builder.write_string("}\n\n")
  }
}

///|
fn render_payloads_and_wrappers(
  builder : StringBuilder,
  commands : Array[ParsedLepusCommand],
) -> Unit {
  for command in commands {
    let payload_params = command_payload_params(command)
    if payload_params.length() > 0 {
      builder.write_string("///|\n")
      builder.write_string("struct ")
      builder.write_string(payload_type_name(command))
      builder.write_string(" {\n")
      for param in payload_params {
        builder.write_string("  ")
        builder.write_string(param.name)
        builder.write_string(" : ")
        builder.write_string(param.param_type)
        builder.write_string("\n")
      }
      builder.write_string("} derive(FromJson)\n\n")
    }
    builder.write_string("///|\n")
    if command.is_async {
      builder.write_string("async ")
    }
    builder.write_string("fn ")
    builder.write_string(wrapper_name(command))
    if command.has_context {
      builder.write_string("(\n")
      builder.write_string(
        "  context : @lepus_command.AppCommandExtensionContext,\n",
      )
      builder.write_string("  payload : ")
      builder.write_string(command_payload_type(command))
      builder.write_string(",\n")
      builder.write_string(") -> ")
    } else {
      builder.write_string("(")
      builder.write_string("payload : ")
      builder.write_string(command_payload_type(command))
      builder.write_string(") -> ")
    }
    builder.write_string(command.return_type)
    builder.write_string(" {\n")
    builder.write_string("  ")
    builder.write_string(command.function_name)
    builder.write_string("(")
    builder.write_string(render_payload_arguments(command))
    builder.write_string(")\n")
    builder.write_string("}\n\n")
  }
}

///|
fn render_extension_spec(
  builder : StringBuilder,
  commands : Array[ParsedLepusCommand],
  scripts : Array[ParsedLepusScript],
  destroy : ParsedLepusDestroy?,
  extension_id : String,
  js_namespace : String,
) -> Unit {
  builder.write_string("///|\n")
  builder.write_string("pub fn extension() -> @lepus_extension.Extension {\n")
  builder.write_string(
    "  @lepus_extension.from_command_spec(__lepus_command_extension_spec())\n",
  )
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string(
    "fn __lepus_command_extension_spec() -> @lepus_command.AppCommandExtensionSpec {\n",
  )
  builder.write_string("  @lepus_command.AppCommandExtensionSpec::new(\n")
  builder.write_string("    ")
  builder.write_string(mbt_string(extension_id))
  builder.write_string(",\n")
  builder.write_string("    ")
  builder.write_string(mbt_string(js_namespace))
  builder.write_string(",\n")
  if commands.length() == 1 {
    builder.write_string("    [@lepus_command.AppCommandApiDescriptor::new(")
    builder.write_string(mbt_string(commands[0].js_name))
    builder.write_string(")],\n")
  } else {
    builder.write_string("    [\n")
    for command in commands {
      builder.write_string("      @lepus_command.AppCommandApiDescriptor::new(")
      builder.write_string(mbt_string(command.js_name))
      builder.write_string("),\n")
    }
    builder.write_string("    ],\n")
  }
  builder.write_string("    fn(context) {\n")
  for command in commands {
    builder.write_string("      context.")
    builder.write_string(registration_method(command))
    builder.write_string("(")
    builder.write_string(mbt_string(command.js_name))
    builder.write_string(", ")
    if command.has_context {
      if command.is_async {
        builder.write_string("async ")
      }
      builder.write_string("fn(payload) {\n")
      builder.write_string("        ")
      builder.write_string(wrapper_name(command))
      builder.write_string("(context, payload)\n")
      builder.write_string("      }")
    } else {
      builder.write_string(wrapper_name(command))
    }
    builder.write_string(")\n")
  }
  builder.write_string("      Ok(())\n")
  builder.write_string("    },\n")
  if scripts.length() > 0 {
    builder.write_string("    scripts=[\n")
    for script in scripts {
      builder.write_string("      ")
      builder.write_string(script.function_name)
      builder.write_string("(),\n")
    }
    builder.write_string("    ],\n")
  }
  match destroy {
    Some(destroy) => {
      builder.write_string("    on_destroy=fn(context) {\n")
      builder.write_string("      ")
      builder.write_string(destroy.function_name)
      if destroy.has_context {
        builder.write_string("(context)\n")
      } else {
        builder.write_string("()\n")
      }
      builder.write_string("    },\n")
    }
    None => ()
  }
  builder.write_string("  )\n")
  builder.write_string("}\n")
}

///|
fn codegen_warnings(parsed : ParsedLepusModule) -> Array[String] {
  let warnings : Array[String] = []
  if parsed.events.length() > 0 {
    for command in parsed.commands {
      if !command.is_async {
        warnings.push(
          "sync command `" +
          command.function_name +
          "` cannot emit generated events in v1; use `async fn` if it needs event emission",
        )
      }
    }
  }
  warnings
}

///|
fn registration_method(command : ParsedLepusCommand) -> String {
  if command.is_async && command.returns_result {
    "op_async_result"
  } else if command.is_async {
    "op_async"
  } else if command.returns_result {
    "op_result"
  } else {
    "op"
  }
}

///|
fn command_payload_type(command : ParsedLepusCommand) -> String {
  if command_payload_params(command).length() == 0 {
    "Unit"
  } else {
    payload_type_name(command)
  }
}

///|
fn command_payload_params(
  command : ParsedLepusCommand,
) -> Array[ParsedLepusParam] {
  command.params.filter(fn(param) { !param.is_context })
}

///|
fn payload_type_name(command : ParsedLepusCommand) -> String {
  "Lepus" + pascal_from_snake(command.function_name) + "Payload"
}

///|
fn wrapper_name(command : ParsedLepusCommand) -> String {
  "__lepus_command_" + command.function_name
}

///|
fn render_payload_arguments(command : ParsedLepusCommand) -> String {
  let args : Array[String] = []
  for param in command.params {
    if param.is_context {
      args.push("context")
    } else {
      args.push("payload." + param.name)
    }
  }
  args.join(", ")
}

///|
fn mbt_string(s : String) -> String {
  "\"" + escape_mbt_string(s) + "\""
}

///|
fn escape_mbt_string(s : String) -> String {
  s
  .replace(old="\\", new="\\\\")
  .replace(old="\"", new="\\\"")
  .replace(old="\n", new="\\n")
  .replace(old="\r", new="\\r")
  .replace(old="\t", new="\\t")
}
