///|
test "attribute codegen renders commands events context and warnings" {
  let generated = match
    generate_app_commands_from_source(
      (
        #|///|
        #|#lepus.command
        #|fn ping() -> PingReply {
        #|  PingReply::{ message: "pong" }
        #|}
        #|
        #|///|
        #|#lepus.command(name="slowAdd")
        #|async fn slow_add(context : @app.AppCommandExtensionContext, left : Int, right : Int, delay_ms : Int?) -> Result[AddReply, String] {
        #|  emit_add_finished(context, AddFinished::{ total: left + right })
        #|  Ok(AddReply::{ total: left + right, waited_ms: delay_ms.unwrap_or(0) })
        #|}
        #|
        #|///|
        #|#lepus.event(name="addFinished")
        #|struct AddFinished {
        #|  total : Int
        #|} derive(ToJson)
        #|
      ),
      "examples/generated-add",
      "add",
    ) {
    Ok(generated) => generated
    Err(error) => abort(error)
  }
  @debug.assert_eq(generated.warnings, [
    "sync command `ping` cannot emit generated events in v1; use `async fn` if it needs event emission",
  ])
  let expected_source =
    #|///|
    #|/// Generated by `lepus codegen commands`. Do not edit by hand.
    #|
    #|///|
    #|pub async fn emit_add_finished(
    #|  context : @app.AppCommandExtensionContext,
    #|  payload : AddFinished,
    #|) -> Unit {
    #|  context.emit("addFinished", payload)
    #|}
    #|
    #|///|
    #|fn __lepus_command_ping(payload : Unit) -> PingReply {
    #|  ping()
    #|}
    #|
    #|///|
    #|struct LepusSlowAddPayload {
    #|  left : Int
    #|  right : Int
    #|  delay_ms : Int?
    #|} derive(FromJson)
    #|
    #|///|
    #|async fn __lepus_command_slow_add(
    #|  context : @app.AppCommandExtensionContext,
    #|  payload : LepusSlowAddPayload,
    #|) -> Result[AddReply, String] {
    #|  slow_add(context, payload.left, payload.right, payload.delay_ms)
    #|}
    #|
    #|///|
    #|pub fn generated_app_command_extension() -> @app.AppCommandExtensionSpec {
    #|  @app.AppCommandExtensionSpec::new(
    #|    "examples/generated-add",
    #|    "add",
    #|    [
    #|      @app.AppCommandApiDescriptor::new("ping"),
    #|      @app.AppCommandApiDescriptor::new("slowAdd"),
    #|    ],
    #|    fn(context) {
    #|      context.op("ping", __lepus_command_ping)
    #|      context.op_async_result("slowAdd", async fn(payload) {
    #|        __lepus_command_slow_add(context, payload)
    #|      })
    #|      Ok(())
    #|    },
    #|  )
    #|}
    #|
  inspect(generated.source, content=expected_source)
}

///|
test "attribute codegen rejects duplicate command names" {
  match
    generate_app_commands_from_source(
      (
        #|#lepus.command(name="ping")
        #|fn ping() -> Unit {}
        #|#lepus.command(name="ping")
        #|fn ping_again() -> Unit {}
        #|
      ),
      "examples/dup",
      "dup",
    ) {
    Ok(_) => abort("expected duplicate command error")
    Err(error) =>
      inspect(error, content="duplicate command JavaScript name: ping")
  }
}

///|
test "attribute codegen rejects defaulted parameters" {
  match
    generate_app_commands_from_source(
      (
        #|#lepus.command
        #|fn ping(name : String = "moon") -> Unit {}
        #|
      ),
      "examples/defaulted",
      "defaulted",
    ) {
    Ok(_) => abort("expected defaulted parameter error")
    Err(error) =>
      inspect(
        error,
        content="failed to parse MoonBit source for #lepus codegen",
      )
  }
}

///|
test "attribute codegen rejects context without events" {
  match
    generate_app_commands_from_source(
      (
        #|#lepus.command
        #|fn ping(context : @app.AppCommandExtensionContext) -> Unit {}
        #|
      ),
      "examples/no-events",
      "noEvents",
    ) {
    Ok(_) => abort("expected context without event error")
    Err(error) =>
      inspect(
        error,
        content=(
          #|context parameter is only supported when #lepus.event helpers are generated: ping
        ),
      )
  }
}

///|
test "attribute codegen rejects unsupported attribute arguments" {
  match
    generate_app_commands_from_source(
      (
        #|#lepus.command(js_name="ping")
        #|fn ping() -> Unit {}
        #|
      ),
      "examples/bad-attr",
      "badAttr",
    ) {
    Ok(_) => abort("expected invalid attribute error")
    Err(error) =>
      inspect(
        error,
        content=(
          #|unsupported #lepus.command attribute arguments: #lepus.command(js_name="ping")
        ),
      )
  }
}

///|
test "attribute codegen rejects unsupported command parameter type" {
  match
    generate_app_commands_from_source(
      (
        #|#lepus.command
        #|fn ping(callback : (Int) -> Int) -> Unit {}
        #|
      ),
      "examples/bad-param",
      "badParam",
    ) {
    Ok(_) => abort("expected unsupported parameter type error")
    Err(error) =>
      inspect(
        error,
        content="unsupported command parameter type in #lepus.command: ping.callback",
      )
  }
}

///|
test "attribute codegen rejects event-only input" {
  match
    generate_app_commands_from_source(
      (
        #|#lepus.event
        #|struct AddFinished {
        #|  total : Int
        #|} derive(ToJson)
        #|
      ),
      "examples/event-only",
      "events",
    ) {
    Ok(_) => abort("expected missing command error")
    Err(error) =>
      inspect(
        error,
        content="#lepus.command codegen requires at least one command",
      )
  }
}

///|
test "attribute codegen file scan reports target parse errors" {
  @mbfs.create_dir("target") catch {
    _ => ()
  }
  @mbfs.create_dir("target/lepus-codegen-bad-target") catch {
    _ => ()
  }
  let input = "target/lepus-codegen-bad-target/input.mbt"
  @mbfs.write_string_to_file(
    input,
    (
      #|#lepus.command
      #|fn broken( -> Unit {}
      #|
    ),
    encoding="utf8",
  ) catch {
    err => abort(@debug.render(@debug.to_repr(err)))
  }
  match generate_app_commands_from_file(input, "examples/bad-target", "bad") {
    Ok(_) => abort("expected target parse error")
    Err(error) =>
      inspect(
        error,
        content=(
          #|failed to parse MoonBit source for #lepus codegen: target/lepus-codegen-bad-target/input.mbt
        ),
      )
  }
}

///|
test "attribute codegen file scan targets input file and checks package context" {
  @mbfs.create_dir("target") catch {
    _ => ()
  }
  @mbfs.create_dir("target/lepus-codegen-package") catch {
    _ => ()
  }
  let input = "target/lepus-codegen-package/input.mbt"
  let sibling = "target/lepus-codegen-package/sibling.mbt"
  @mbfs.write_string_to_file(
    input,
    (
      #|#lepus.command
      #|fn ping() -> Unit {}
      #|
    ),
    encoding="utf8",
  ) catch {
    err => abort(@debug.render(@debug.to_repr(err)))
  }
  @mbfs.write_string_to_file(
    sibling,
    (
      #|#lepus.command
      #|fn other() -> Unit {}
      #|
    ),
    encoding="utf8",
  ) catch {
    err => abort(@debug.render(@debug.to_repr(err)))
  }
  let generated = generate_app_commands_from_file(
    input, "examples/package", "pkg",
  ).unwrap()
  inspect(generated.source.contains("__lepus_command_ping"), content="true")
  inspect(generated.source.contains("__lepus_command_other"), content="false")
  @mbfs.write_string_to_file(
    sibling,
    (
      #|#lepus.command(name="ping")
      #|fn other() -> Unit {}
      #|
    ),
    encoding="utf8",
  ) catch {
    err => abort(@debug.render(@debug.to_repr(err)))
  }
  match generate_app_commands_from_file(input, "examples/package", "pkg") {
    Ok(_) => abort("expected duplicate name from package context")
    Err(error) =>
      inspect(error, content="duplicate command JavaScript name: ping")
  }
}
