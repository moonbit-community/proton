product_name = {{title_mbt}}
identifier = {{identifier_mbt}}

window = {
  title: {{title_mbt}},
  width: {{width}},
  height: {{height}},
  size_hint: "none",
}

entry = {
  kind: "asset",
  value: "app/app.html",
}

debug = true

bundle = {
  active: true,
  targets: ["app", "zip"],
  output: "target/proton-dist",
}
