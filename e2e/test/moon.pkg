import {
  "moonbitlang/async",
  "moonbitlang/core/env",
  "moonbitlang/core/string",
  "justjavac/cdp/client",
}

supported_targets = "native"

pkgtype(kind: "executable")

options(
  targets: {
    "cdp_eval.mbt": [ "native" ],
    "env.mbt": [ "native" ],
    "main.mbt": [ "native" ],
    "probes.mbt": [ "native" ],
    "ready.mbt": [ "native" ],
  },
)
