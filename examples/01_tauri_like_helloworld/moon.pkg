import {
  "moonbitlang/core/json",
  "justjavac/proton/webview",
  "justjavac/ffi",
}

supported_targets = "native"

dev_build(rule: "embed", input: "index.html", output: "index.mbt")

options(
  formatter: { "ignore": [ "index.mbt" ] },
  "is-main": true,
  targets: { "main.mbt": [ "native" ] },
)
