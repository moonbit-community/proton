import {
  "moonbitlang/core/json",
  "justjavac/lepus/webview",
  "justjavac/ffi",
}

supported_targets = "native"

options(
  "is-main": true,
  "pre-build": [
    {
      "command": ":embed -i $input -o $output",
      "input": "index.html",
      "output": "index.mbt",
    },
  ],
  targets: { "main.mbt": [ "native" ] },
)
