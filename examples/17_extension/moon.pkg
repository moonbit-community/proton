import {
  "moonbitlang/async",
  "moonbitlang/core/json",
  "justjavac/proton/core",
  "justjavac/proton",
}

supported_targets = "native"

dev_build(rule: "embed", input: "extension.html", output: "extension.mbt")

formatter(ignore: [ "extension.mbt" ])

options(
  "is-main": true,
  targets: { "main.mbt": [ "native" ], "math_extension.mbt": [ "native" ] },
)
