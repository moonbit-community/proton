import {
  "extensions/fs",
  "justjavac/lepus/core" @core,
  "justjavac/lepus/webview" @webview,
}

supported_targets = "native"

options(
  "is-main": true,
  "pre-build": [
    {
      "command": ":embed -i $input -o $output",
      "input": "fs.html",
      "output": "fs.mbt",
    },
  ],
  targets: { "main.mbt": [ "native" ] },
)
