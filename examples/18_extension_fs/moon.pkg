import {
  "justjavac/proton_ext/fs",
  "justjavac/proton/core",
  "justjavac/proton/webview",
}

supported_targets = "native"

dev_build(rule: "embed", input: "fs.html", output: "fs.mbt")

options(
  formatter: { "ignore": [ "fs.mbt" ] },
  "is-main": true,
  targets: { "main.mbt": [ "native" ] },
)
