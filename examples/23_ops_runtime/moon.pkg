import {
  "moonbitlang/async",
  "justjavac/proton_ext/fs",
  "justjavac/proton_ext/path",
  "justjavac/proton",
}

supported_targets = "native"

dev_build(rule: "embed", input: "app.html", output: "app.mbt")

options(
  formatter: { "ignore": [ "app.mbt" ] },
  "is-main": true,
  targets: { "main.mbt": [ "native" ] },
)
