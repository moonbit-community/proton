import {
  "moonbitlang/async",
  "justjavac/proton_ext/path",
  "justjavac/proton",
}

supported_targets = "native"

options(
  "is-main": true,
  "pre-build": [
    {
      "command": ":embed -i $input -o $output",
      "input": "app.html",
      "output": "app.mbt",
    },
  ],
  targets: { "main.mbt": [ "native" ] },
)
