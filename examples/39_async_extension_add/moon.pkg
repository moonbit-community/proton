import {
  "moonbitlang/core/json",
  "moonbitlang/async" @async,
  "justjavac/lepus_core" @core,
  "justjavac/lepus" @webview,
}

supported_targets = "native"

options(
  "is-main": true,
  "pre-build": [
    {
      "command": ":embed -i $input -o $output",
      "input": "app.html",
      "output": "app.mbt",
    },
  ],
  targets: { "main.mbt": [ "native" ], "add_extension.mbt": [ "native" ] },
)
