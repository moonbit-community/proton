import {
  "moonbitlang/x/fs" @mbfs,
  "moonbitlang/core/json",
  "moonbitlang/async",
  "justjavac/lepus_core" @core,
  "justjavac/lepus_app",
  "justjavac/lepus_manifest" @manifest,
}

supported_targets = "native"

options(
  "is-main": true,
  "pre-build": [
    {
      "command": ":embed -i $input -o $output",
      "input": "app.html",
      "output": "app.mbt",
    },
  ],
  targets: { "main.mbt": [ "native" ] },
)
