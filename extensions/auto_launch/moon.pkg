import {
  "moonbitlang/core/json",
  "justjavac/auto_launch" @sys_auto_launch,
  "justjavac/proton/command" @proton_command,
  "justjavac/proton/extension" @proton_extension,
}

supported_targets = "native"

options(
  formatter: { "ignore": [ "extension.g.mbt" ] },
  targets: {
    "auto_launch.mbt": [ "native" ],
    "extension.g.mbt": [ "native" ],
    "extension.mbt": [ "native" ],
    "extension_wbtest.mbt": [ "native" ],
  },
)
