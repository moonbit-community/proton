import {
  "moonbitlang/core/json",
  "justjavac/global_hotkey" @sys_global_hotkey,
  "justjavac/lepus/command" @lepus_command,
  "justjavac/lepus/extension" @lepus_extension,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": "$mod_dir/../target/lepus-tools/lepus codegen $input -o $output",
      "input": "extension.mbt",
      "output": "extension.g.mbt",
    },
  ],
  targets: {
    "extension.g.mbt": [ "native" ],
    "extension.mbt": [ "native" ],
    "extension_wbtest.mbt": [ "native" ],
    "global_hotkey.mbt": [ "native" ],
  },
)
