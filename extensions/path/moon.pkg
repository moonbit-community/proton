import {
  "moonbitlang/core/json",
  "moonbitlang/x/path" @mbpath,
  "justjavac/proton/core",
  "justjavac/proton/extension" @proton_extension,
}

supported_targets = "native"

options(
  formatter: { "ignore": [ "generated_path_helper_template.mbt" ] },
  targets: {
    "extension.mbt": [ "native" ],
    "helper_js.mbt": [ "native" ],
    "path_api.mbt": [ "native" ],
    "path_wbtest.mbt": [ "native" ],
  },
)
