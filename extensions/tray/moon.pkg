import {
  "moonbitlang/core/json",
  "justjavac/tray" @sys_tray,
  "justjavac/lepus",
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": "$mod_dir/../target/lepus-tools/lepus codegen $input -o $output",
      "input": "extension.mbt",
      "output": "extension.g.mbt",
    },
  ],
  targets: { "extension.g.mbt": [ "native" ], "extension.mbt": [ "native" ] },
)
