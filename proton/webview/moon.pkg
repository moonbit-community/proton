import {
  "moonbitlang/core/json",
  "moonbitlang/core/encoding/utf8",
  "justjavac/ffi",
}

import {
  "justjavac/ffi",
  "moonbitlang/x/sys",
} for "test"

supported_targets = "+native"

options(
  "native-stub": [ "stub.c" ],
  link: { "native": { "stub-cc-flags": "${build.PROTON_CEF_STUB_CC_FLAGS}" } },
  targets: { "binding.mbt": [ "native" ], "webview.mbt": [ "native" ] },
)
